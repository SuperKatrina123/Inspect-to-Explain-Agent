# LLM API key (OpenAI-compatible)
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI-compatible base URL (default: https://9985678.xyz/v1)
LLM_BASE_URL=https://api.openai.com/v1

# Model name (default: gpt-5.4)
LLM_MODEL=gpt-4o

# Set to "true" to use real LLM; "false" falls back to mock
USE_LLM=true

# Server port
PORT=3001

# Absolute path to project root for source code search
CODE_SEARCH_ROOT=/absolute/path/to/your/project
